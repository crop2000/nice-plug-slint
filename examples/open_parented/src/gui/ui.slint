import { Knob } from "DSL/knob.slint";

export component AppWindow inherits Window {
    preferred-width: 300px;
    preferred-height: 360px;

    min-width: 240px;
    min-height: 290px;

    // Normalized gain value (0.0 – 1.0)
    in-out property <float> gain-value: 0.75;

    // dB display string pushed from Rust each frame
    in-out property <string> gain-db: "0.0 dB";

    callback gain-changed(float);
    callback gain-begin-drag();
    callback gain-end-drag();

    property <float> scale: min(root.width / 300px, root.height / 360px);

    background: #141414;

    // The UI scales with the window. `scale` is derived from root.width/height,
    // so the scaled child sizes must NOT feed back into the window's reported
    // size — otherwise Slint reports a binding loop:
    //   scale -> font-size -> layoutinfo -> root.layoutinfo -> root.height -> scale
    //
    // A `*Layout` (VerticalLayout/HorizontalLayout) aggregates its children's
    // sizes into its own layoutinfo, which is exactly the feedback edge that
    // closes the loop. To break it, we lay everything out *manually* inside a
    // plain Rectangle sized to the window: a Rectangle does not compute its
    // layoutinfo from its children, so the scaled sizes never propagate back up
    // to the window and the cycle is severed. The window's actual size is driven
    // externally by baseview/nice-plug-slint from SlintEditorState, so we lose
    // nothing by not sizing-to-content here.
    Rectangle {
        width: root.width;
        height: root.height;
        clip: true;

        // Vertical layout is reconstructed by hand. We compute a content block
        // height from the scaled pieces and centre it vertically, mirroring the
        // old `VerticalLayout { alignment: center }` look.
        property <length> pad: 32px * root.scale;
        property <length> knob-size: 180px * root.scale;

        // Stacked content height (header + divider + gaps + knob + readout +
        // label + vendor), used only to centre the block — it is a plain value,
        // not a layout constraint, so it does not feed back into the window.
        property <length> content-h:
            16px * root.scale            // header text
            + 12px * root.scale          // gap
            + 1px                        // divider
            + 28px * root.scale          // gap
            + self.knob-size             // knob
            + 20px * root.scale          // gap
            + 22px * root.scale          // dB readout
            + 4px * root.scale           // gap
            + 13px * root.scale          // OUTPUT GAIN label
            + 20px * root.scale          // gap
            + 11px * root.scale;         // vendor tag

        property <length> top: (root.height - self.content-h) / 2;

        // Running y-cursor for manual stacking
        property <length> y-header: self.top;
        property <length> y-divider: self.y-header + 16px * root.scale + 12px * root.scale;
        property <length> y-knob: self.y-divider + 1px + 28px * root.scale;
        property <length> y-readout: self.y-knob + self.knob-size + 20px * root.scale;
        property <length> y-label: self.y-readout + 22px * root.scale + 4px * root.scale;
        property <length> y-vendor: self.y-label + 13px * root.scale + 20px * root.scale;

        // Plugin name header
        Text {
            x: (parent.width - self.width) / 2;
            y: parent.y-header;
            text: "GAIN";
            color: #ffffff;
            font-size: 13px * root.scale;
            font-weight: 700;
            letter-spacing: 4px * root.scale;
            horizontal-alignment: center;
        }

        // Subtle divider
        Rectangle {
            x: (parent.width - self.width) / 2;
            y: parent.y-divider;
            height: 1px;
            width: 40px * root.scale;
            background: #2a2a2a;
        }

        // The knob — centred horizontally
        Knob {
            x: (parent.width - self.width) / 2;
            y: parent.y-knob;
            width: parent.knob-size;
            height: parent.knob-size;
            value <=> root.gain-value;
            minimum: 0.0;
            maximum: 1.0;

            changed(v) => {
                root.gain-changed(v);
            }
            begin-drag() => {
                root.gain-begin-drag();
            }
            end-drag() => {
                root.gain-end-drag();
            }
        }

        // dB readout
        Text {
            x: (parent.width - self.width) / 2;
            y: parent.y-readout;
            text: root.gain-db;
            color: #06b6d4;
            font-size: 18px * root.scale;
            font-weight: 600;
            horizontal-alignment: center;
        }

        // "OUTPUT GAIN" label below readout
        Text {
            x: (parent.width - self.width) / 2;
            y: parent.y-label;
            text: "OUTPUT GAIN";
            color: #555555;
            font-size: 10px * root.scale;
            font-weight: 600;
            letter-spacing: 2px * root.scale;
            horizontal-alignment: center;
        }

        // Vendor tag
        Text {
            x: (parent.width - self.width) / 2;
            y: parent.y-vendor;
            text: "ADNMRTNS";
            color: #333333;
            font-size: 9px * root.scale;
            horizontal-alignment: center;
        }
    }
}
